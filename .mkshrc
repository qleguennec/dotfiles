export MAIL42=qle-guen@student.42.fr
export USER42=qle-guen
export EDITOR=nvim
export FCEDIT=nvim
export PATH="$PATH:$HOME/.bin"
export PS1='[0;36m$(pwd | sed "s,^$HOME,~,") [0;37mλ[0m '
export WP="$HOME/wp"

set -o ignoreeof

if [[ `uname` == 'Darwin' ]]
then
	export HOMEBREW_CACHE=/tmp/mycache
	export HOMEBREW_TEMP=/tmp/mytemp
	export PATH="$PATH:/$HOME/.brew/bin"
	alias brew="$HOME/.brew/bin/brew"

	alias l='ls -lah -G'
else
	alias l='ls -lah -G --color=auto'
fi

alias ls='ls -G'

alias gca='git commit -a'
alias ga='git add'
alias gp='git push'
alias gs='git status'

alias v='nvim'

alias rel='source $HOME/.mkshrc'

MAINGIT="http://github.com/qleguennec"

function maingit() {
	git clone "$MAINGIT/$1.git"
}

function lnl() {
	ln -s "$WP/lib$1" ./
}

function libs() {
	for lib in `ls -d lib*`; do
		make -C "$lib" $1
	done
}

function wp() {
	cd $WP/$1
}

function test() {
	cd $WP/test-lib$1
}

function lib() {
	cd $WP/lib$1
}

function extest() {
	test $1
	make ex
}
