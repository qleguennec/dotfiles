export MAIL42=qle-guen@student.42.fr
export USER42=qle-guen
export EDITOR=nvim
export FCEDIT=nvim
export PATH="$PATH:$HOME/.bin"
export PS1='[0;36m$(pwd | sed "s,^$HOME,~,") [0;37mλ[0m '
export WP="$HOME/wp"

if [[ `uname` == 'Darwin' ]]
then
	export HOMEBREW_CACHE=/tmp/mycache
	export HOMEBREW_TEMP=/tmp/mytemp
	export PATH="$PATH:/$HOME/.brew/bin"
fi

alias ls='ls -G'
alias l='ls -lah -G --color=auto'

alias gca='git commit -a'
alias ga='git add'
alias gp='git push'

alias v='nvim'

function re-libs() {
	for lib in `ls -d lib*`; do
		make -C "$lib" re
	done
}
