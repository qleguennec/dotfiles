filetype plugin indent on

call plug#begin()

call plug#end()

colorscheme zellner

set linebreak
set showbreak=+++
set textwidth=100
set showmatch
set visualbell
set wildmenu

set hlsearch
set smartcase
set ignorecase
set incsearch
syntax on

set ruler
set wildignore+=*/tmp/*,*.o,*.a,build/* 

set undolevels=1000
